{
	"extends": "@sofie-automation/code-standard-preset/ts/tsconfig.lib",
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules/**", "**/*spec.ts", "**/__tests__/*", "**/__mocks__/*"],
	"compilerOptions": {
		"target": "es2024",
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./",
		"resolveJsonModule": true,
		"types": ["node"],
		"composite": true,
		"module": "node20",
		"skipLibCheck": true,
		"verbatimModuleSyntax": true
	}
}
